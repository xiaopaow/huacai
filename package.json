{
  "name": "huacai-amazon-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "test": "vitest run",
    "clean": "node -e \"const fs=require('node:fs'); for (const path of ['dist','server-dist']) fs.rmSync(path,{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.server.json --noEmit && tsc -b && vite build && tsc -p tsconfig.server.build.json",
    "deploy:check": "node scripts/deploy-preflight.mjs",
    "start": "node server-dist/index.js",
    "start:server": "tsx server/index.ts",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "helmet": "^8.1.0",
    "lowdb": "^7.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "read-excel-file": "^9.2.0",
    "sharp": "^0.34.5",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
